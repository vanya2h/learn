{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm withenv -- react-router dev",
    "build": "pnpm withenv -- react-router build",
    "start": "pnpm withenv -- react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:generate": "pnpm withenv -- prisma generate",
    "db:migrate": "pnpm withenv -- prisma migrate dev",
    "db:push": "pnpm withenv -- prisma db push",
    "db:studio": "pnpm withenv -- prisma studio",
    "db:reset": "pnpm withenv -- prisma migrate reset",
    "withenv": "dotenv -e ../../.env",
    "test": "vitest run",
    "i18n:extract": "lingui extract",
    "i18n:compile": "lingui compile",
    "gen:gradient": "node --experimental-strip-types --no-warnings scripts/gen-gradient.ts",
    "backfill:cover": "pnpm withenv -- node --experimental-strip-types --no-warnings scripts/backfill-cover.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@base-ui/react": "^1.4.1",
    "@better-auth/infra": "^0.2.5",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@hono/zod-validator": "^0.7.6",
    "@hookform/resolvers": "^5.2.2",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "@lingui/core": "^6.0.1",
    "@lingui/react": "^6.0.1",
    "@paper-design/shaders-react": "~0.0.76",
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "^7.8.0",
    "@react-router/node": "^7.14.2",
    "@react-router/serve": "^7.14.2",
    "@streamdown/code": "^1.1.1",
    "@vanya2h/utils-rxjs-react": "0.8.0-rc.1",
    "better-auth": "^1.6.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv-cli": "^8.0.0",
    "hono": "^4.12.15",
    "isbot": "^5",
    "jotai": "^2.20.0",
    "jsonrepair": "^3.14.0",
    "lodash": "^4.17.21",
    "lucide-react": "^1.14.0",
    "mitt": "^3.0.1",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.74.0",
    "react-router": "^7.14.2",
    "rxjs": "^7.8.1",
    "shadcn": "^4.7.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "unpdf": "^1.6.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "@lingui/babel-plugin-lingui-macro": "^6.0.1",
    "@lingui/cli": "^6.0.1",
    "@lingui/vite-plugin": "^6.0.1",
    "@react-router/dev": "^7.14.2",
    "@tailwindcss/vite": "^4.0.0",
    "@types/lodash": "^4.17.13",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-babel": "^1.6.0",
    "vitest": "^4.1.5"
  }
